{
  "version": 2,
  "name": "gayathry-portfolio",
  "outputDirectory": "build/web",
  "buildCommand": "flutter/bin/flutter build web --release",
  "installCommand": "git clone https://github.com/flutter/flutter.git --depth 1 -b stable flutter",
  "framework": null,
  "routes": [
    {
      "src": "/resume",
      "dest": "/resume/resumeV1.pdf"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.wasm)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
