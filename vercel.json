{
  "version": 2,
  "name": "gayathry-portfolio",
  "outputDirectory": "build/web",
  "buildCommand": "flutter/bin/flutter build web --release && cp -r web/resume build/web/resume",
  "installCommand": "git clone https://github.com/flutter/flutter.git --depth 1 -b stable flutter",
  "framework": null,
  "redirects": [
    {
      "source": "/resume",
      "destination": "/resume/resumeV2.pdf",
      "permanent": false
    },
    {
      "source": "/resume/",
      "destination": "/resume/resumeV2.pdf",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
